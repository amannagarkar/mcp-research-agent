# MCP Server Configuration
MCP_PORT=3001

# Choose ONE of the following LLM providers by setting its API key
# The MCP server will automatically detect which provider is available

# ===== OpenAI (Default) =====
# Set these to use OpenAI GPT models
# OPENAI_API_KEY= <Key Here>
# OPENAI_MODEL=gpt-4.0

# ===== Claude (Anthropic) =====
# Uncomment and set these to use Claude
# ANTHROPIC_API_KEY=sk-ant-your-claude-api-key-here
# CLAUDE_MODEL=claude-3-5-sonnet-20241022

# ===== Deepseek =====
# Uncomment and set these to use Deepseek
# DEEPSEEK_API_KEY=<Key Here>
# DEEPSEEK_MODEL=deepseek-chat

# ===== Gemini =====
# Uncomment and set these to use Gemini
# GEMINI_API_KEY=your-gemini-api-key-here
# GEMINI_MODEL=gemini-1.5-pro

# Backend Configuration
PORT=3000
DATABASE_URL=postgresql://user:password@localhost:5432/research_papers
MCP_URL=http://localhost:3001

# Frontend Configuration
VITE_API_URL=http://localhost:3000/api
